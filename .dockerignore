# Dependencies
# Docker's ignore matching is not identical to gitignore on every sender path.
# Keep both forms so nested workspace node_modules are never traversed/sent,
# especially Windows/WSL pnpm symlinks/junctions that Docker Desktop may fail to open.
node_modules
**/node_modules
.pnpm-store
**/.pnpm-store

# Build outputs
.next
dist
server/bin
server/tmp

# Git
.git
.gitignore

# Environment
.env
.env.*
!.env.example

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test
e2e/test-results
coverage

# Docs
docs/

# Desktop app (not needed for web self-hosting)
apps/desktop
